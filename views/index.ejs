        </div>
        <div class="flame-decals">
          <img src="/images/upgrades/flame.jpg" alt="">
          <p>Flame Decals</p>
        </div>
        <div class="bumper-stickers">
          <img src="/images/upgrades/bumper_sticker.jpg" alt="">
          <p>Bumper Stickers</p>
        </div>
        <div class="hub-caps">
          <img src="/images/upgrades/hub-cap.jpg" alt="">
          <p>Hub Cap</p>
        </div>
      </div>
    </div>
  </div>
</div>