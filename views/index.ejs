<h1 class="welcome">Welcome to CSE Motors!</h1>

<div class="hero">
  <picture>
    <source media="(min-width: 768px)" srcset="/images/vehicles/delorean.jpg">

    <img src="/images/vehicles/delorean-tn.jpg" alt="delorean car">
  </picture>
  <div class="car-info">
    <p><strong>DMC delorean</strong> <br>
      3 Cup holders <br>
      Superman doors <br>
      Fuzzy dize!</p>
